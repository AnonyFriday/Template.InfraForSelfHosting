# FileBrowser Docker Environment Variables

# Web UI Port
FILEBROWSER_PORT=8080

# User/Group IDs (match your host user for permission compatibility)
PUID=1000
PGID=1000

# Root directory to browse
# This path on the host is mounted to /srv inside the container
FILE_ROOT=/

# Default Credentials
# ===================
# Username: admin
# Password: admin
# CHANGE IMMEDIATELY after first login

# Configuration
# =============
# settings.json is created automatically on first run.
# You can customize it to change:
# - Default scope per user
# - Branding
# - Command execution permissions